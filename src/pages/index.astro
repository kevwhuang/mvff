---
import heroPoster from '@assets/images/hero-poster.webp';
import heroVideo from '@assets/videos/hero-video.webm';
import logo from '@assets/images/logo.png';
import logoCabana from '@assets/images/logo-cabana.png';
import logoMadewell from '@assets/images/logo-madewell.png';
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>ATX Music Video Film Festival | July 18, 2026</title>
        <meta
            name="description"
            content="Screens to Stage — An immersive production blending music and film, celebrating artists. Music video screenings, live performances, Q&A panels, award ceremony, and pool party. July 18, 7PM–2AM at Cabana Club, Austin TX."
        />
        <meta
            name="keywords"
            content="ATX Music Video Film Festival, Austin film festival, music video screening, live music Austin, film awards, Cabana Club, Texas film festival, music video awards, 2026 festival, summer festival Austin"
        />
        <meta name="author" content="ATX Music Video Film Festival" />
        <meta name="robots" content="index, follow" />
        <link rel="canonical" href="https://atxmusicvideofilmfestival.com" />
        <link rel="icon" href="favicon.png" type="image/png" />
        <meta property="og:type" content="event" />
        <meta
            property="og:title"
            content="ATX Music Video Film Festival | July 18, 2026"
        />
        <meta
            property="og:description"
            content="Screens to Stage — Music video screenings, live performances, award ceremony & pool party. July 18 at Cabana Club, Austin TX."
        />
        <meta
            property="og:image"
            content="https://atxmusicvideofilmfestival.com/og.png"
        />
        <meta property="og:url" content="https://atxmusicvideofilmfestival.com" />
        <meta property="og:site_name" content="ATX Music Video Film Festival" />
        <meta property="og:locale" content="en_US" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta
            name="twitter:title"
            content="ATX Music Video Film Festival | July 18, 2026"
        />
        <meta
            name="twitter:description"
            content="Screens to Stage — Music video screenings, live performances, award ceremony & pool party. Austin TX."
        />
        <meta
            name="twitter:image"
            content="https://atxmusicvideofilmfestival.com/og.png"
        />
        <meta name="twitter:site" content="@atxmvff" />
        <meta name="theme-color" content="#0a0f1a" />
        <meta
            http-equiv="Content-Security-Policy"
            content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; media-src 'self'; connect-src 'self'"
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Space+Grotesk:wght@500;600;700&display=swap"
            rel="stylesheet"
        />
        <link
            rel="preload"
            href={logo.src}
            as="image"
            fetchpriority="high"
        />
        <script
            set:html={JSON.stringify({
                '@context': 'https://schema.org',
                '@type': 'Event',
                'name': 'ATX Music Video Film Festival',
                'description': 'Screens to Stage — An immersive production blending music and film, celebrating artists.',
                'startDate': '2026-07-18T19:00:00-05:00',
                'endDate': '2026-07-19T02:00:00-05:00',
                'eventStatus': 'https://schema.org/EventScheduled',
                'eventAttendanceMode': 'https://schema.org/OfflineEventAttendanceMode',
                'location': {
                    '@type': 'Place',
                    'name': 'Cabana Club',
                    'address': {
                        '@type': 'PostalAddress',
                        'addressLocality': 'Austin',
                        'addressRegion': 'TX',
                        'addressCountry': 'US',
                    },
                },
                'organizer': {
                    '@type': 'Organization',
                    'name': 'ATX Music Video Film Festival',
                    'url': 'https://atxmusicvideofilmfestival.com',
                },
                'image': new URL(logo.src, 'https://atxmusicvideofilmfestival.com').href,
            })}
            type="application/ld+json"
        />
        <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      :root {
        --c-accent: #ff4d6d;
        --c-accent-dark: #e8445f;
        --c-bg: #0a0f1a;
        --c-bg-dark: #080c14;
        --c-bg-light: #0c1322;
        --c-bg-lighter: #0e1528;
        --c-border: #ffffff26;
        --c-border-accent: #ff4d6d80;
        --c-highlight-cyan: #22d3ee;
        --c-highlight-indigo: #6366f1;
        --c-highlight-purple: #c084fc;
        --c-overlay: #0a0f1ae6;
        --c-surface: #ffffff0d;
        --c-text: #fff;
        --c-text-muted: #a8b2c1;
        --ease: 150ms ease;
        --ease-md: 0.3s ease;
        --ease-reveal: 1.5s cubic-bezier(0.22, 1, 0.36, 1);
        --ease-slow: 0.6s ease;
        --f-body: "Space Grotesk", system-ui, sans-serif;
        --f-display: "Archivo Black", Impact, sans-serif;
        --fs-2xl: 2rem;
        --fs-base: 1rem;
        --fs-sm: 0.875rem;
        --fs-xl: 1.5rem;
        --gradient-angle: 0deg;
        --max-w: 1536px;
        --nav-h: clamp(60px, calc(60px + 40 * (100vw - 320px) / 1216), 100px);
        --s-2xl: 5rem;
        --page-px: clamp(15px, calc(15px + 35 * (100vw - 320px) / 1216), 50px);
        --section-gap: clamp(300px, calc(300px + 200 * (100vw - 320px) / 1216), 500px);
        --s-lg: 2rem;
        --s-md: 1.5rem;
        --s-sm: 1rem;
        --s-xs: 0.5rem;
      }
      @property --gradient-angle {
        inherits: false;
        initial-value: 0deg;
        syntax: "<angle>";
      }
      html {
        overflow-x: hidden;
        scroll-behavior: smooth;
      }
      body {
        background: var(--c-bg);
        color: var(--c-text);
        cursor: none;
        font-family: var(--f-body);
        font-size: var(--fs-base);
        font-weight: 600;
        line-height: 1.6;
        min-height: 100vh;
        overflow-x: hidden;
      }
      a,
      button {
        cursor: none;
      }
      .stars {
        background: linear-gradient(
          180deg,
          var(--c-bg),
          var(--c-bg-light) 25%,
          var(--c-bg-lighter) 50%,
          var(--c-bg-light) 75%,
          var(--c-bg-dark)
        );
        inset: 0;
        overflow: hidden;
        position: fixed;
        z-index: -1;
      }
      .stars__layer {
        backface-visibility: hidden;
        inset: 0;
        position: absolute;
        will-change: transform;
      }
      .stars__layer--1 {
        animation: twinkle 6s ease-in-out infinite alternate;
        background-image:
          radial-gradient(1px 1px at 8% 12%, rgba(255, 255, 255, 0.9), transparent),
          radial-gradient(1px 1px at 22% 28%, rgba(255, 255, 255, 0.7), transparent),
          radial-gradient(1px 1px at 38% 18%, rgba(255, 255, 255, 0.8), transparent),
          radial-gradient(1px 1px at 58% 8%, rgba(255, 255, 255, 0.6), transparent),
          radial-gradient(1px 1px at 78% 22%, rgba(255, 255, 255, 0.9), transparent),
          radial-gradient(1px 1px at 92% 35%, rgba(255, 255, 255, 0.7), transparent),
          radial-gradient(1px 1px at 12% 48%, rgba(255, 255, 255, 0.8), transparent),
          radial-gradient(1px 1px at 45% 42%, rgba(255, 255, 255, 0.5), transparent),
          radial-gradient(1px 1px at 68% 38%, rgba(255, 255, 255, 0.6), transparent),
          radial-gradient(1px 1px at 85% 52%, rgba(255, 255, 255, 0.7), transparent),
          radial-gradient(1px 1px at 5% 68%, rgba(255, 255, 255, 0.8), transparent),
          radial-gradient(1px 1px at 32% 62%, rgba(255, 255, 255, 0.5), transparent),
          radial-gradient(1px 1px at 55% 72%, rgba(255, 255, 255, 0.6), transparent),
          radial-gradient(1px 1px at 75% 65%, rgba(255, 255, 255, 0.9), transparent),
          radial-gradient(1px 1px at 95% 78%, rgba(255, 255, 255, 0.7), transparent),
          radial-gradient(1px 1px at 18% 85%, rgba(255, 255, 255, 0.8), transparent),
          radial-gradient(1px 1px at 42% 92%, rgba(255, 255, 255, 0.6), transparent),
          radial-gradient(1px 1px at 65% 88%, rgba(255, 255, 255, 0.75), transparent),
          radial-gradient(1px 1px at 88% 95%, rgba(255, 255, 255, 0.85), transparent);
      }
      .stars__layer--2 {
        animation: twinkle 8s ease-in-out infinite alternate-reverse;
        background-image:
          radial-gradient(2px 2px at 15% 10%, #fff, transparent),
          radial-gradient(2px 2px at 48% 22%, rgba(255, 255, 255, 0.8), transparent),
          radial-gradient(2px 2px at 82% 15%, rgba(255, 255, 255, 0.9), transparent),
          radial-gradient(2px 2px at 8% 42%, rgba(255, 255, 255, 0.7), transparent),
          radial-gradient(2px 2px at 62% 48%, rgba(255, 255, 255, 0.5), transparent),
          radial-gradient(2px 2px at 92% 55%, #fff, transparent),
          radial-gradient(2px 2px at 25% 68%, rgba(255, 255, 255, 0.85), transparent),
          radial-gradient(2px 2px at 72% 75%, rgba(255, 255, 255, 0.75), transparent),
          radial-gradient(2px 2px at 5% 88%, rgba(255, 255, 255, 0.8), transparent),
          radial-gradient(2px 2px at 55% 92%, rgba(255, 255, 255, 0.9), transparent),
          radial-gradient(2px 2px at 88% 85%, rgba(255, 255, 255, 0.8), transparent),
          radial-gradient(2px 2px at 38% 35%, rgba(255, 255, 255, 0.5), transparent);
      }
      .stars__layer--3 {
        animation: twinkle 10s ease-in-out infinite alternate;
        background-image:
          radial-gradient(3px 3px at 10% 25%, rgba(255, 255, 255, 0.9), transparent),
          radial-gradient(3px 3px at 52% 18%, rgba(255, 255, 255, 0.85), transparent),
          radial-gradient(3px 3px at 85% 42%, rgba(255, 255, 255, 0.8), transparent),
          radial-gradient(3px 3px at 22% 72%, rgba(255, 255, 255, 0.9), transparent),
          radial-gradient(3px 3px at 68% 65%, rgba(255, 255, 255, 0.85), transparent),
          radial-gradient(3px 3px at 92% 88%, rgba(255, 255, 255, 0.9), transparent);
      }
      .stars__layer--4 {
        background-image:
          radial-gradient(6px 6px at 12% 15%, #fff, rgba(255, 255, 255, 0.5) 30%, rgba(255, 255, 255, 0.08) 60%, transparent),
          radial-gradient(5px 5px at 55% 25%, #fff, rgba(255, 255, 255, 0.15) 30%, transparent 60%),
          radial-gradient(7px 7px at 88% 42%, #fff, rgba(255, 255, 255, 0.45) 30%, rgba(255, 255, 255, 0.07) 60%, transparent),
          radial-gradient(10px 10px at 25% 62%, #fff, rgba(255, 255, 255, 0.4) 20%, var(--c-surface) 50%, transparent),
          radial-gradient(8px 8px at 72% 78%, #fff, rgba(255, 255, 255, 0.5) 25%, rgba(255, 255, 255, 0.07) 55%, transparent),
          radial-gradient(7px 7px at 8% 85%, #fff, rgba(255, 255, 255, 0.4) 30%, rgba(255, 255, 255, 0.06) 60%, transparent),
          radial-gradient(9px 9px at 15% 48%, #fff, rgba(255, 255, 255, 0.3) 25%, var(--c-surface) 50%, transparent),
          radial-gradient(8px 8px at 92% 68%, #fff, rgba(255, 255, 255, 0.45) 25%, rgba(255, 255, 255, 0.06) 55%, transparent);
      }
      @keyframes twinkle {
        from {
          opacity: 0.5;
        }
        to {
          opacity: 1;
        }
      }
      .loader {
        align-items: center;
        background: var(--c-bg);
        display: flex;
        inset: 0;
        justify-content: center;
        overflow: hidden;
        position: fixed;
        transition:
          opacity var(--ease-slow),
          visibility var(--ease-slow);
        z-index: 9999;
      }
      .loader--hidden {
        opacity: 0;
        visibility: hidden;
      }
      .loader__content {
        align-items: center;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
      }
      .loader__logo {
        animation: loader-pulse 1.5s ease-in-out infinite;
        height: auto;
        position: relative;
        width: 200px;
        z-index: 1;
      }
      .loader__bar {
        background: var(--c-border);
        border-radius: 3px;
        height: 3px;
        margin-top: 2rem;
        overflow: hidden;
        width: 200px;
      }
      .loader__progress {
        animation: loader-fill 0.8s ease-out forwards;
        background: var(--c-accent);
        height: 100%;
      }
      .loader__percent {
        color: var(--c-accent);
        font-family: var(--f-display);
        font-size: 1.5rem;
        letter-spacing: 0.1em;
        margin-top: 1rem;
      }
      .loader__pulse {
        animation: loader-ring 3s ease-out infinite;
        border: 1px solid rgba(255, 77, 109, 0.25);
        border-radius: 50%;
        height: 350px;
        left: 50%;
        margin: -175px 0 0 -175px;
        position: absolute;
        top: 50%;
        width: 350px;
        z-index: 0;
      }
      .loader__pulse:nth-child(2) {
        animation-delay: 1s;
      }
      .loader__pulse:nth-child(3) {
        animation-delay: 2s;
      }
      @keyframes loader-pulse {
        0%,
        100% {
          opacity: 0.5;
          transform: scale(0.98);
        }
        50% {
          opacity: 1;
          transform: scale(1);
        }
      }
      @keyframes loader-ring {
        0% {
          opacity: 0.5;
          transform: scale(1);
        }
        100% {
          opacity: 0;
          transform: scale(2.5);
        }
      }
      @keyframes loader-fill {
        from {
          width: 0;
        }
        to {
          width: 100%;
        }
      }
      .grain {
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        inset: 0;
        opacity: 0.04;
        pointer-events: none;
        position: fixed;
        z-index: 1000;
      }
      .shapes {
        inset: 0;
        overflow: hidden;
        pointer-events: none;
        position: fixed;
        z-index: -1;
      }
      .shapes__blob {
        animation: float 30s ease-in-out infinite;
        backface-visibility: hidden;
        border-radius: 50%;
        filter: blur(100px);
        opacity: 0.08;
        position: absolute;
        will-change: transform;
      }
      .shapes__blob--1 {
        background: var(--c-accent);
        height: 400px;
        left: 5%;
        top: 10%;
        width: 400px;
      }
      .shapes__blob--2 {
        animation-delay: -10s;
        background: var(--c-highlight-indigo);
        height: 300px;
        right: 5%;
        top: 60%;
        width: 300px;
      }
      .shapes__blob--3 {
        animation-delay: -20s;
        background: var(--c-highlight-cyan);
        bottom: 10%;
        height: 250px;
        left: 30%;
        width: 250px;
      }
      @keyframes float {
        0%,
        100% {
          transform: translate(0, 0);
        }
        50% {
          transform: translate(30px, 20px);
        }
      }
      .cursor {
        backface-visibility: hidden;
        background: radial-gradient(
          circle,
          rgba(255, 77, 109, 0.4) 0%,
          transparent 70%
        );
        border-radius: 50%;
        height: 30px;
        left: -15px;
        pointer-events: none;
        position: fixed;
        top: -15px;
        width: 30px;
        will-change: transform;
        z-index: 9998;
      }
      .cursor__dot {
        backface-visibility: hidden;
        background: var(--c-accent);
        border-radius: 50%;
        height: 6px;
        left: -3px;
        pointer-events: none;
        position: fixed;
        top: -3px;
        width: 6px;
        will-change: transform;
        z-index: 9999;
      }
      .cursor--hover {
        height: 50px;
        left: -25px;
        top: -25px;
        width: 50px;
      }
      .no-select {
        -webkit-user-select: none;
        user-select: none;
      }
      .sr-only {
        border: 0;
        clip: rect(0, 0, 0, 0);
        height: 1px;
        margin: -1px;
        overflow: hidden;
        padding: 0;
        position: absolute;
        white-space: nowrap;
        width: 1px;
      }
      .reveal {
        opacity: 0;
        transition: opacity var(--ease-reveal);
      }
      .reveal--visible {
        opacity: 1;
      }
      .reveal--delay-1 {
        transition-delay: 0.1s;
      }
      .reveal--delay-2 {
        transition-delay: 0.2s;
      }
      .reveal--delay-3 {
        transition-delay: 0.3s;
      }
      .reveal--delay-4 {
        transition-delay: 0.4s;
      }
      .reveal--delay-5 {
        transition-delay: 0.5s;
      }
      .skip-link {
        background: var(--c-accent);
        border-radius: 0 0 8px 8px;
        color: var(--c-bg);
        font-weight: 800;
        left: 50%;
        padding: var(--s-sm) var(--s-md);
        position: absolute;
        text-decoration: none;
        top: -100%;
        transform: translateX(-50%);
        transition: top var(--ease);
        z-index: 1000;
      }
      .skip-link:focus {
        outline: 3px solid var(--c-text);
        outline-offset: 2px;
        top: 0;
      }
      :focus-visible {
        outline: 3px solid var(--c-accent);
        outline-offset: 3px;
      }
      .scroll-progress {
        background: linear-gradient(90deg, var(--c-accent), var(--c-highlight-indigo), var(--c-highlight-cyan));
        height: 3px;
        left: 0;
        position: fixed;
        top: 0;
        transition: width 0.1s ease-out;
        width: 0%;
        z-index: 101;
      }
      .nav {
        align-items: center;
        backdrop-filter: blur(10px);
        background: var(--c-overlay);
        border-bottom: 1px solid var(--c-border);
        display: flex;
        height: var(--nav-h);
        inset: 0 0 auto;
        position: fixed;
        z-index: 100;
      }
      .nav__inner {
        align-items: center;
        display: flex;
        gap: clamp(10px, calc(10px + 20 * (100vw - 320px) / 1216), 30px);
        justify-content: space-between;
        margin: 0 auto;
        max-width: var(--max-w);
        padding: 0 clamp(10px, calc(10px + 20 * (100vw - 320px) / 1216), 30px);
        width: 100%;
      }
      .nav__logo {
        align-items: center;
        display: flex;
      }
      .nav__logo-img {
        height: clamp(30px, calc(30px + 20 * (100vw - 320px) / 1216), 50px);
        width: auto;
      }
      .nav__countdown {
        align-items: center;
        color: var(--c-text-muted);
        display: none;
        height: clamp(30px, calc(30px + 20 * (100vw - 320px) / 1216), 50px);
        font-family: var(--f-body);
        font-size: clamp(10px, calc(10px + 5 * (100vw - 320px) / 1216), 15px);
        font-weight: 600;
        gap: clamp(6px, calc(6px + 4 * (100vw - 320px) / 1216), 10px);
        letter-spacing: 0.05em;
      }
      .nav__countdown-num {
        align-items: center;
        display: flex;
        flex-direction: column;
        min-width: clamp(18px, calc(18px + 12 * (100vw - 320px) / 1216), 30px);
      }
      .nav__countdown-val {
        color: var(--c-accent);
        font-family: var(--f-display);
        font-size: clamp(15px, calc(15px + 10 * (100vw - 320px) / 1216), 25px);
        line-height: 1;
      }
      .nav__countdown-label {
        font-size: clamp(6px, calc(6px + 4 * (100vw - 320px) / 1216), 10px);
        opacity: 0.7;
        text-transform: uppercase;
      }
      .nav__countdown-sep {
        color: var(--c-accent);
        font-size: clamp(12px, calc(12px + 8 * (100vw - 320px) / 1216), 20px);
        opacity: 0.5;
      }
      .nav__links {
        align-items: center;
        display: flex;
        gap: clamp(10px, calc(10px + 5 * (100vw - 320px) / 1216), 15px);
        justify-content: flex-end;
      }
      .nav__cta {
        align-items: center;
        animation: cta-glow 2s ease-in-out infinite;
        background: var(--c-accent);
        border-radius: clamp(4px, calc(4px + 4 * (100vw - 320px) / 1216), 8px);
        box-shadow: 0 3px 15px rgba(255, 77, 109, 0.4);
        color: var(--c-text);
        display: inline-flex;
        font-size: clamp(12px, calc(12px + 3 * (100vw - 320px) / 1216), 15px);
        font-weight: 800;
        height: clamp(30px, calc(30px + 20 * (100vw - 320px) / 1216), 50px);
        justify-content: center;
        letter-spacing: 0.05em;
        line-height: 1;
        padding: 0 clamp(10px, calc(10px + 5 * (100vw - 320px) / 1216), 15px);
        text-align: center;
        text-decoration: none;
        text-transform: uppercase;
        transition:
          background var(--ease),
          box-shadow var(--ease);
      }
      .nav__cta:hover {
        animation: none;
        background: var(--c-accent-dark);
        box-shadow: 0 5px 18px rgba(255, 77, 109, 0.5);
      }
      .nav__burger {
        align-items: center;
        background: var(--c-surface);
        border: 1px solid var(--c-border);
        border-radius: clamp(4px, calc(4px + 4 * (100vw - 320px) / 1216), 8px);
        color: var(--c-text);
        display: inline-flex;
        height: clamp(30px, calc(30px + 20 * (100vw - 320px) / 1216), 50px);
        justify-content: center;
        width: clamp(30px, calc(30px + 20 * (100vw - 320px) / 1216), 50px);
        transition:
          background var(--ease),
          border-color var(--ease);
      }
      .nav__burger:hover {
        background: var(--c-surface);
        border-color: rgba(255, 255, 255, 0.5);
      }
      .nav__burger-icon {
        height: clamp(15px, calc(15px + 10 * (100vw - 320px) / 1216), 25px);
        width: clamp(15px, calc(15px + 10 * (100vw - 320px) / 1216), 25px);
      }
      .nav__burger-line--1 {
        transform-origin: 12px 4px;
        transition: transform var(--ease-md), opacity var(--ease-md);
      }
      .nav__burger-line--2 {
        transform-origin: 12px 12px;
        transition: opacity var(--ease-md);
      }
      .nav__burger-line--3 {
        transform-origin: 12px 20px;
        transition: transform var(--ease-md), opacity var(--ease-md);
      }
