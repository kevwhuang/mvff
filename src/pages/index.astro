        <script is:inline>
      (() => {
          const loader = document.querySelector('.loader');
          const percent = document.querySelector('.loader__percent');
          let p = 0;
          const loadInterval = setInterval(() => {
              p += Math.random() * 15 + 5;
              if (p >= 100) {
                  p = 100;
                  clearInterval(loadInterval);
                  percent.textContent = '100%';
                  setTimeout(() => loader.classList.add('loader--hidden'), 200);
              } else {
                  percent.textContent = Math.floor(p) + '%';
              }
          }, 100);
          const scrollProgress = document.querySelector('.scroll-progress');
          const updateScrollProgress = () => {
              const scrollTop = window.scrollY;
              const docHeight =
                  document.documentElement.scrollHeight - window.innerHeight;
              const progress = (scrollTop / docHeight) * 100;
              scrollProgress.style.width = progress + '%';
          };
          const layers = document.querySelectorAll('[data-parallax]');
          let ticking = false;
          const updateParallax = () => {
              const y = window.scrollY;
              layers.forEach(
                  l =>
                      (l.style.transform = `translateY(${y * +l.dataset.parallax}px)`),
              );
              updateScrollProgress();
              ticking = false;
          };
          window.addEventListener(
              'scroll',
              () => {
                  if (!ticking) {
                      requestAnimationFrame(updateParallax);
                      ticking = true;
                  }
              },
              { passive: true },
          );
          const reveals = document.querySelectorAll('.reveal');
          const observer = new IntersectionObserver(
              entries =>
                  entries.forEach(
                      e =>
                          e.isIntersecting && e.target.classList.add('reveal--visible'),
                  ),
              { threshold: 0.3, rootMargin: '0px 0px -30% 0px' },
          );
          const footerObserver = new IntersectionObserver(
              entries =>
                  entries.forEach(
                      e =>
                          e.isIntersecting && e.target.classList.add('reveal--visible'),
                  ),
              { threshold: 0.1 },
          );
          if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
              reveals.forEach(el => el.classList.add('reveal--visible'));
              loader.classList.add('loader--hidden');
          } else {
              setTimeout(() => {
                  reveals.forEach((el) => {
                      if (el.classList.contains('footer')) {
                          footerObserver.observe(el);
                      } else {
                          observer.observe(el);
                      }
                  });
              }, 1000);
          }
          const eventDate = new Date('2026-07-18T19:00:00-05:00').getTime();
          const countdownEls = {
              days: document.getElementById('countdown-days'),
              hours: document.getElementById('countdown-hours'),
              mins: document.getElementById('countdown-mins'),
              secs: document.getElementById('countdown-secs'),
          };
          const countdownContainer = document.querySelector('.nav__countdown');
          const updateCountdown = () => {
              const now = Date.now();
              const diff = eventDate - now;
              if (diff <= 0) {
                  countdownContainer.innerHTML = '<span class="nav__countdown-val" style="font-size:24px;letter-spacing:0.1em">HAPPENING NOW</span>';
                  clearInterval(countdownInterval);
                  return;
              }
              const d = Math.floor(diff / 86400000);
              const h = Math.floor((diff % 86400000) / 3600000);
              const m = Math.floor((diff % 3600000) / 60000);
              const s = Math.floor((diff % 60000) / 1000);
              if (countdownEls.days)
                  countdownEls.days.textContent = String(d).padStart(2, '0');
              if (countdownEls.hours)
                  countdownEls.hours.textContent = String(h).padStart(2, '0');
              if (countdownEls.mins)
                  countdownEls.mins.textContent = String(m).padStart(2, '0');
              if (countdownEls.secs)
                  countdownEls.secs.textContent = String(s).padStart(2, '0');
          };
          updateCountdown();
          const countdownInterval = setInterval(() => {
              updateCountdown();
          }, 1000);
          const cards = document.querySelectorAll(
              '.details__item, .categories__item',
          );
          cards.forEach((card) => {
              card.addEventListener('mousemove', (e) => {
                  const rect = card.getBoundingClientRect();
                  const x = e.clientX - rect.left;
                  const y = e.clientY - rect.top;
                  const centerX = rect.width / 2;
                  const centerY = rect.height / 2;
                  const rotateX = (y - centerY) / 15;
                  const rotateY = (centerX - x) / 15;
                  card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
              });
              card.addEventListener('mouseleave', () => {
                  card.style.transform =
                      'perspective(1000px) rotateX(0) rotateY(0) scale3d(1, 1, 1)';
              });
          });
          const cursor = document.querySelector('.cursor');
          const dot = document.querySelector('.cursor__dot');
          let cursorX = 0,
              cursorY = 0,
              cursorRaf = false;
          const updateCursor = () => {
              cursor.style.transform = `translate(${cursorX}px, ${cursorY}px)`;
              dot.style.transform = `translate(${cursorX}px, ${cursorY}px)`;
              cursorRaf = false;
          };
          document.addEventListener(
              'mousemove',
              (e) => {
                  cursorX = e.clientX;
                  cursorY = e.clientY;
                  if (!cursorRaf) {
                      cursorRaf = true;
                      requestAnimationFrame(updateCursor);
                  }
              },
              { passive: true },
          );
          document.querySelectorAll('a, button').forEach((el) => {
              el.addEventListener('mouseenter', () =>
                  cursor.classList.add('cursor--hover'),
              );
              el.addEventListener('mouseleave', () =>
                  cursor.classList.remove('cursor--hover'),
              );
          });
          const chars = 'iljtfr1|/';
          const scrambleText = (el) => {
              const original = el.dataset.original || el.textContent;
              el.dataset.original = original;
              let iteration = 0;
              const interval = setInterval(() => {
                  el.textContent = original
                      .split('')
                      .map((char, i) => {
                          if (i < iteration) return original[i];
                          if (char === ' ') return ' ';
                          return chars[Math.floor(Math.random() * chars.length)];
                      })
                      .join('');
                  iteration += 0.5;
                  if (iteration >= original.length) {
                      clearInterval(interval);
                      el.textContent = original;
                  }
              }, 30);
          };
          const scrambles = document.querySelectorAll('[data-scramble]');
          scrambles.forEach((el) => {
              const mo = new MutationObserver(() => {
                  if (el.classList.contains('reveal--visible')) {
                      scrambleText(el);
                      mo.disconnect();
                  }
              });
              mo.observe(el, { attributes: true, attributeFilter: ['class'] });
          });
          const typed = document.querySelector('.tagline__typed');
          if (typed) {
              const text = typed.dataset.text;
              const textSpan = document.createElement('span');
              textSpan.className = 'tagline__typed-text';
              typed.appendChild(textSpan);
              let i = 0;
              const typeWriter = () => {
                  if (i < text.length) {
                      textSpan.textContent += text.charAt(i);
                      i++;
                      setTimeout(typeWriter, 25);
                  } else {
                      typed.classList.add('tagline__typed--done');
                  }
              };
              const taglineObserver = new IntersectionObserver(
                  (entries) => {
                      if (entries[0].isIntersecting) {
                          setTimeout(typeWriter, 500);
                          taglineObserver.disconnect();
                      }
                  },
                  { threshold: 0.5 },
              );
              taglineObserver.observe(typed.closest('.tagline'));
          }
          const modal = document.querySelector('.categories__modal');
          const modalText = modal.querySelector('.categories__modal-text');
          const modalItems = document.querySelectorAll('.categories__item[data-modal]');
          let activeItem = null;
          const positionModal = (item) => {
              const rect = item.getBoundingClientRect();
              const mw = 340;
              let left = rect.left + rect.width / 2 - mw / 2;
              left = Math.max(12, Math.min(left, window.innerWidth - mw - 12));
              modal.style.width = mw + 'px';
              modal.style.left = left + 'px';
              modal.style.top = rect.bottom + 36 + 'px';
              const arrowLeft = rect.left + rect.width / 2 - left;
              modal.style.setProperty('--arrow-left', arrowLeft + 'px');
          };
          let showTimeout = null;
          const showModal = (item) => {
              const text = item.dataset.modal;
              if (!text) return;
              if (showTimeout) clearTimeout(showTimeout);
              modal.classList.remove('categories__modal--visible');
              modal.style.transition = 'none';
              void modal.offsetHeight;
              modal.style.transition = '';
              modalText.textContent = text;
              positionModal(item);
              showTimeout = setTimeout(() => {
                  modal.classList.add('categories__modal--visible');
                  modal.style.transform = 'translateY(0)';
              }, 10);
              activeItem = item;
          };
          const hideModal = () => {
              modal.classList.remove('categories__modal--visible');
              activeItem = null;
          };
          modalItems.forEach((item) => {
              item.addEventListener('mouseenter', () => showModal(item));
              item.addEventListener('mouseleave', hideModal);
              item.addEventListener('click', (e) => {
                  if (!matchMedia('(hover: hover)').matches) {
                      e.stopPropagation();
                      if (activeItem === item) {
                          hideModal();
                      } else {
                          showModal(item);
                      }
                  }
              });
          });
          document.addEventListener('click', (e) => {
              if (activeItem && !e.target.closest('.categories__item')) hideModal();
          });
          window.addEventListener('scroll', hideModal, { passive: true });
          const burger = document.querySelector('.nav__burger');
          const menu = document.querySelector('.nav__menu');
          burger.addEventListener('click', () => {
              const isOpen = burger.classList.toggle('nav__burger--open');
              menu.classList.toggle('nav__menu--open');
              burger.setAttribute('aria-expanded', isOpen);
              menu.setAttribute('aria-hidden', !isOpen);
          });
      })();
        </script>
    </body>
