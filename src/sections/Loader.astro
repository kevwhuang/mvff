---
import logo from '@assets/images/logos/mvff.png';
---

<div class="loader fixed flex items-center justify-center overflow-hidden" aria-hidden="true">
    <div class="loader__content relative flex flex-col items-center justify-center">
        <div class="loader__pulse absolute rounded-full"></div>
        <div class="loader__pulse absolute rounded-full"></div>
        <div class="loader__pulse absolute rounded-full"></div>
        <img
            class="loader__logo select-none"
            alt=""
            fetchpriority="high"
            src={logo.src}
        />
        <div class="loader__bar"><div class="loader__progress"></div></div>
        <div class="loader__percent select-none">0%</div>
    </div>
</div>

<style>
    .loader {
        background: var(--c-base);
        inset: 0;
        transition:
            opacity var(--xs-2),
            visibility var(--xs-2);
        z-index: 9999;
    }

    .loader[data-hidden] {
        opacity: 0;
        visibility: hidden;
    }

    .loader__logo {
        animation: loader-pulse 1.5s ease-in-out infinite;
        height: auto;
        position: relative;
        width: var(--l-2);
        z-index: 1;
    }

    .loader__bar {
        background: color-mix(in srgb, var(--c-text) 15%, transparent);
        border-radius: var(--r-3);
        height: 3px;
        margin-top: var(--s-3);
        overflow: hidden;
        width: var(--l-2);
    }

    .loader__progress {
        animation: loader-fill 0.8s ease-out forwards;
        background: var(--c-brand);
        height: 100%;
    }

    .loader__percent {
        color: var(--c-brand);
        font-family: var(--ff-heading);
        font-size: var(--fs-3);
        letter-spacing: 0.1em;
        margin-top: var(--s-4);
    }

    .loader__pulse {
        animation: loader-ring 3s ease-out infinite;
        border: 1px solid color-mix(in srgb, var(--c-brand) 25%, transparent);
        height: var(--l-1);
        left: 50%;
        margin: calc(var(--l-1) / -2) 0 0 calc(var(--l-1) / -2);
        top: 50%;
        width: var(--l-1);
        z-index: 0;
    }

    .loader__pulse:nth-child(2) {
        animation-delay: 1s;
    }

    .loader__pulse:nth-child(3) {
        animation-delay: 2s;
    }

    @keyframes loader-fill {
        from {
            width: 0;
        }
        to {
            width: 100%;
        }
    }

    @keyframes loader-pulse {
        0%,
        100% {
            opacity: 0.5;
            transform: scale(0.98);
        }
        50% {
            opacity: 1;
            transform: scale(1);
        }
    }

    @keyframes loader-ring {
        0% {
            opacity: 0.5;
            transform: scale(1);
        }
        100% {
            opacity: 0;
            transform: scale(2.5);
        }
    }

    @media (prefers-reduced-motion: reduce), (hover: none), (pointer: coarse) {
        .loader {
            display: none;
        }
    }
</style>

<script>
    const HIDE_DELAY = 200;
    const MAX_PROGRESS = 100;
    const PROGRESS_BASE = 5;
    const PROGRESS_RANGE = 15;
    const TICK_INTERVAL = 100;

    const loader = document.querySelector('.loader');

    if (loader) {
        const percent = document.querySelector('.loader__percent');
        let progress = 0;

        const loadInterval = setInterval(() => {
            progress += Math.random() * PROGRESS_RANGE + PROGRESS_BASE;

            if (progress >= MAX_PROGRESS) {
                progress = MAX_PROGRESS;
                clearInterval(loadInterval);

                if (percent) {
                    percent.textContent = '100%';
                }

                setTimeout(() => loader.setAttribute('data-hidden', ''), HIDE_DELAY);
            } else if (percent) {
                percent.textContent = Math.floor(progress) + '%';
            }
        }, TICK_INTERVAL);

        if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
            loader.setAttribute('data-hidden', '');
        }
    }
</script>
