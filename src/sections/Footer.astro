---
import EmailIcon from '@components/icons/Email.astro';
import InstagramIcon from '@components/icons/Instagram.astro';
---

<footer class="footer">
    <div class="footer__inner flex flex-col items-center">
        <nav class="footer__links flex" aria-label="Social links">
            <a
                class="footer__link inline-flex items-center justify-center rounded-full"
                aria-label="Follow us on Instagram (opens in new tab)"
                href="https://instagram.com/atxmvff"
                rel="noopener noreferrer"
                target="_blank"
            >
                <InstagramIcon class="footer__icon" />
            </a>
            <a
                class="footer__link inline-flex items-center justify-center rounded-full"
                aria-label="Send us an email"
                href="mailto:contact@atxmusicvideofilmfestival.com"
            >
                <EmailIcon class="footer__icon" />
            </a>
        </nav>
        <p class="footer__copy">&copy; 2026 ATX Music Video Film Festival. All rights reserved.</p>
    </div>
</footer>

<style>
    .footer {
        margin: 0 auto;
        max-width: var(--l-max);
        padding: var(--l-2) var(--l-3);
    }

    .footer__links {
        gap: var(--s-2);
        margin-bottom: var(--s-2);
    }

    .footer__link {
        background: color-mix(in srgb, var(--c-text) 5%, transparent);
        border: 1px solid color-mix(in srgb, var(--c-text) 15%, transparent);
        color: var(--c-text);
        height: var(--l-3);
        transition:
            background var(--xs-4),
            border-color var(--xs-4),
            color var(--xs-4);
        width: var(--l-3);
    }

    .footer__link:hover {
        background: color-mix(in srgb, var(--c-brand) 10%, transparent);
        border-color: color-mix(in srgb, var(--c-brand) 50%, transparent);
        color: var(--c-brand);
    }

    .footer__icon {
        height: var(--fs-3);
        width: var(--fs-3);
    }

    .footer__copy {
        color: var(--c-muted);
        font-size: var(--fs-5);
        letter-spacing: 0.05em;
        text-align: center;
    }
</style>
