---
import heroPoster from '@assets/images/hero/poster.webp';
import heroVideo from '@assets/videos/hero.webm';
import logo from '@assets/images/logos/mvff.png';
---

<header class="hero relative flex items-center justify-center overflow-hidden">
    <video
        class="hero__video absolute object-cover"
        aria-hidden="true"
        autoplay
        loop
        muted
        playsinline
        poster={heroPoster.src}
    >
        <source src={heroVideo} type="video/webm" />
    </video>
    <img
        class="hero__img select-none"
        alt="ATX Music Video Film Festival"
        data-scroll
        data-scroll-duration="10"
        decoding="async"
        height="700"
        src={logo.src}
        width="700"
    />
</header>

<style>
    .hero {
        background: var(--c-base);
        box-sizing: border-box;
        min-height: 100vh;
        padding-top: var(--l-nav);
        z-index: 1;
    }

    .hero__video {
        filter: saturate(0.8);
        height: 100%;
        inset: 0;
        opacity: 0.15;
        width: 100%;
        z-index: -1;
    }

    .hero__img {
        height: auto;
        max-width: calc(var(--l-max) - var(--l-3) * 2);
        width: 100%;
    }
</style>
