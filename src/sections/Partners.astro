---
import logoCabana from '@assets/images/logos/cabana.png';
import logoMadewell from '@assets/images/logos/madewell.png';
---

<section class="partners" aria-label="Presented by" data-scroll>
    <div class="partners__marquee overflow-hidden">
        <div class="partners__track flex items-center">
            <img class="partners__logo partners__logo--madewell shrink-0 object-contain select-none" alt="Madewell Productions" src={logoMadewell.src} />
            <img class="partners__logo shrink-0 object-contain select-none" alt="Cabana Club" src={logoCabana.src} />
            <img class="partners__logo partners__logo--madewell shrink-0 object-contain select-none" alt="" aria-hidden="true" src={logoMadewell.src} />
            <img class="partners__logo shrink-0 object-contain select-none" alt="" aria-hidden="true" src={logoCabana.src} />
            <img class="partners__logo partners__logo--madewell shrink-0 object-contain select-none" alt="" aria-hidden="true" src={logoMadewell.src} />
            <img class="partners__logo shrink-0 object-contain select-none" alt="" aria-hidden="true" src={logoCabana.src} />
        </div>
    </div>
</section>

<style>
    .partners {
        contain: layout style;
        margin: 0 auto;
        max-width: var(--l-max);
        padding: 0 var(--l-3);
    }

    .partners__marquee {
        mask: linear-gradient(90deg, transparent, #fff 15%, #fff 85%, transparent);
        width: 100%;
        -webkit-mask: linear-gradient(90deg, transparent, #fff 15%, #fff 85%, transparent);
    }

    .partners__track {
        animation: marquee 30s linear infinite;
        animation-play-state: paused;
        gap: var(--l-2);
        width: max-content;
    }

    .partners__track[data-active] {
        animation-play-state: running;
    }

    .partners__logo {
        height: var(--fs-1);
        width: auto;
    }

    .partners__logo--madewell {
        filter: invert(0.85);
    }

    @keyframes marquee {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-33.333%);
        }
    }
</style>

<script>
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import gsap from 'gsap';

    gsap.registerPlugin(ScrollTrigger);

    ScrollTrigger.create({
        once: true,
        onEnter: () => {
            document.querySelector('.partners__track')?.setAttribute('data-active', '');
        },
        start: 'bottom bottom',
        trigger: '.partners',
    });
</script>
