---
import DateIcon from '@components/icons/Date.astro';
import DetailsCard from '@components/blocks/DetailsCard.astro';
import TimeIcon from '@components/icons/Time.astro';
import VenueIcon from '@components/icons/Venue.astro';
---

<section class="details" aria-labelledby="details-heading">
    <h2 id="details-heading" class="details__heading" data-scramble data-scroll>
        The Event
    </h2>
    <ul class="details__grid flex flex-col items-stretch list-none">
        <DetailsCard delay="0.1" label="Venue" value="Cabana Club">
            <VenueIcon class="details__icon relative" />
        </DetailsCard>
        <DetailsCard delay="0.2" label="Date" value="July 18">
            <DateIcon class="details__icon relative" />
        </DetailsCard>
        <DetailsCard delay="0.3" label="Time" value="7&nbsp;PM&nbsp;&rarr;&nbsp;2&nbsp;AM">
            <TimeIcon class="details__icon relative" />
        </DetailsCard>
    </ul>
</section>

<style>
    .details {
        contain: layout style;
        margin: 0 auto;
        max-width: var(--l-max);
        padding: 0 var(--l-3);
    }

    .details__heading {
        color: var(--c-brand);
        font-family: var(--ff-heading);
        font-size: var(--fs-1);
        letter-spacing: 0.02em;
        margin-bottom: var(--s-1);
        text-align: center;
        text-shadow:
            0 0 60px color-mix(in srgb, var(--c-brand) 60%, transparent),
            0 0 120px color-mix(in srgb, var(--c-brand) 30%, transparent);
    }

    .details__grid {
        align-items: stretch;
        flex-direction: column;
        gap: var(--s-3);
        justify-content: center;
    }

    @media (min-width: 1280px) {
        .details__grid {
            flex-direction: row;
        }
    }

    .details__icon {
        height: var(--fs-2);
        margin-bottom: var(--s-4);
        stroke: var(--c-brand);
        width: var(--fs-2);
        z-index: 1;
    }


    @keyframes stroke-reveal {
        to {
            stroke-dashoffset: 0;
        }
    }
</style>

<script>
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import gsap from 'gsap';

    gsap.registerPlugin(ScrollTrigger);

    const ICON_ANIMATION = 'stroke-reveal 2.5s ease-out forwards';
    const PERSPECTIVE = 1000;
    const TILT_DIVISOR = 15;
    const TILT_SCALE = 1.02;

    document.querySelectorAll('.details__icon').forEach((icon) => {
        const paths = icon.querySelectorAll('path, circle, rect, line, polyline');

        ScrollTrigger.create({
            once: true,
            onEnter: () => {
                paths.forEach((path) => {
                    (path as HTMLElement).style.animation = ICON_ANIMATION;
                });
            },
            start: 'bottom bottom',
            trigger: icon.closest('[data-scroll]') || icon,
        });
    });

    document.querySelectorAll('.details__grid > *').forEach((card) => {
        card.addEventListener('mousemove', (event) => {
            const mouseEvent = event as MouseEvent;
            const rect = card.getBoundingClientRect();
            const offsetX = mouseEvent.clientX - rect.left;
            const offsetY = mouseEvent.clientY - rect.top;
            const rotateX = (rect.height / 2 - offsetY) / TILT_DIVISOR;
            const rotateY = (offsetX - rect.width / 2) / TILT_DIVISOR;
            (card as HTMLElement).style.transform = `perspective(${PERSPECTIVE}px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(${TILT_SCALE}, ${TILT_SCALE}, ${TILT_SCALE})`;
        });

        card.addEventListener('mouseleave', () => {
            (card as HTMLElement).style.transform = `perspective(${PERSPECTIVE}px) rotateX(0) rotateY(0) scale3d(1, 1, 1)`;
        });
    });
</script>
