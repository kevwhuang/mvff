---
import TeamCard from '@components/TeamCard.astro';
import amiiri from '@assets/images/team/amiiri.webp';
import anna from '@assets/images/team/anna.webp';
import ben from '@assets/images/team/ben.webp';
import donovan from '@assets/images/team/donovan.webp';
import jasmine from '@assets/images/team/jasmine.webp';
import jymes from '@assets/images/team/jymes.webp';
import killian from '@assets/images/team/killian.webp';
import marissa from '@assets/images/team/marissa.webp';
import phillip from '@assets/images/team/phillip.webp';
import rocky from '@assets/images/team/rocky.webp';
import sebastian from '@assets/images/team/sebastian.webp';
---

<section class="team" aria-labelledby="team-heading">
    <h1 id="team-heading" class="team__heading text-center">2026 Team</h1>
    <ul class="team__grid grid list-none">
        <TeamCard name="Anna" title="Founder & Director" image={anna} />
        <TeamCard name="Rocky" title="Film Director" image={rocky} />
        <TeamCard name="Jasmine" title="Event Coordinator" image={jasmine} />
        <TeamCard name="Jymes" title="Talent Programmer" image={jymes} />
        <TeamCard name="Amiiri" title="Promotions Queen" image={amiiri} />
        <TeamCard name="Donovan" title="Social Media Manager" image={donovan} />
        <TeamCard name="Marissa" title="Graphic Designer" image={marissa} />
        <TeamCard name="Sebastian" title="Community Outreach" image={sebastian} />
        <TeamCard name="Phillip" title="Volunteer Coordinator" image={phillip} />
        <TeamCard name="Killian" title="Visual Tech" image={killian} />
        <TeamCard name="Ben" title="Audio Tech" image={ben} />
    </ul>
</section>

<style>
    .team {
        margin: 0 auto;
        max-width: var(--max-w);
        padding: 0 var(--page-px);
    }

    .team__heading {
        color: var(--c-accent);
        font-family: var(--f-display);
        font-size: var(--fs-1);
        letter-spacing: 0.02em;
        margin-bottom: 0.3em;
        text-shadow:
            0 0 60px rgba(255, 77, 109, 0.6),
            0 0 120px rgba(255, 77, 109, 0.3);
    }

    .team__grid {
        gap: clamp(1rem, 3vw, 1.5rem);
        grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
    }
</style>
