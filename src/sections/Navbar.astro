---
import BurgerIcon from '@components/icons/Burger.astro';
import logo from '@assets/images/logos/mvff.png';
---

<nav class="navbar fixed flex items-center" aria-label="Main">
    <div class="navbar__inner flex items-center justify-between">
        <a class="navbar__logo flex items-center" aria-label="ATX MVFF Home" href="/">
            <img class="navbar__logo-img select-none" alt="" src={logo.src} />
        </a>
        <div class="navbar__countdown select-none" aria-label="Countdown to event" aria-live="polite" aria-atomic="true">
            <div class="navbar__countdown-num flex flex-col items-center">
                <span id="countdown-days" class="navbar__countdown-val">--</span>
                <span class="navbar__countdown-label uppercase">Days</span>
            </div>
            <span class="navbar__countdown-sep">:</span>
            <div class="navbar__countdown-num flex flex-col items-center">
                <span id="countdown-hours" class="navbar__countdown-val">--</span>
                <span class="navbar__countdown-label uppercase">Hrs</span>
            </div>
            <span class="navbar__countdown-sep">:</span>
            <div class="navbar__countdown-num flex flex-col items-center">
                <span id="countdown-mins" class="navbar__countdown-val">--</span>
                <span class="navbar__countdown-label uppercase">Min</span>
            </div>
            <span class="navbar__countdown-sep">:</span>
            <div class="navbar__countdown-num flex flex-col items-center">
                <span id="countdown-secs" class="navbar__countdown-val">--</span>
                <span class="navbar__countdown-label uppercase">Sec</span>
            </div>
        </div>
        <div class="navbar__links flex items-center justify-end">
            <a
                class="navbar__cta inline-flex items-center justify-center text-center uppercase no-underline"
                aria-label="Submit your music video"
                href="https://filmfreeway.com/atxmusicvideofilmfestival"
                rel="noopener noreferrer"
                target="_blank"
            >
                Submit Video<span class="sr-only"> (opens in new tab)</span>
            </a>
            <button class="navbar__burger inline-flex items-center justify-center" aria-expanded="false" aria-label="Open menu">
                <BurgerIcon />
            </button>
        </div>
    </div>
</nav>
<div class="navbar__menu fixed flex flex-col items-center justify-center pointer-events-none" aria-hidden="true">
    <a class="navbar__menu-link no-underline" href="/">Home</a>
    <a class="navbar__menu-link no-underline" href="/team">Team</a>
    <div class="navbar__menu-divider"></div>
    <a class="navbar__menu-link no-underline" href="pitch-deck.pdf" rel="noopener noreferrer" target="_blank">Pitch Deck</a>
    <a class="navbar__menu-link no-underline" href="https://calendly.com/madewellanna99/30min" rel="noopener noreferrer" target="_blank">Schedule a Call</a>
</div>

<style>
    .navbar {
        backdrop-filter: blur(10px);
        background: color-mix(in srgb, var(--c-base) 90%, transparent);
        border-bottom: 1px solid color-mix(in srgb, var(--c-text) 15%, transparent);
        height: var(--l-nav);
        inset: 0 0 auto;
        z-index: 100;
    }

    .navbar__inner {
        display: grid;
        gap: var(--s-3);
        grid-template-columns: 1fr auto 1fr;
        margin: 0 auto;
        max-width: var(--l-max);
        padding: 0 var(--l-3);
        width: 100%;
    }

    .navbar__logo-img {
        height: var(--s-2);
        width: auto;
    }

    .navbar__countdown {
        align-items: center;
        color: var(--c-muted);
        display: flex;
        font-family: var(--ff-body);
        font-size: var(--fs-6);
        font-weight: 600;
        gap: var(--s-4);
        height: var(--s-2);
        letter-spacing: 0.05em;
    }

    .navbar__countdown-num {
        min-width: var(--s-3);
    }

    .navbar__countdown-val {
        color: var(--c-brand);
        font-family: var(--ff-heading);
        font-size: var(--fs-4);
        line-height: 1;
    }

    .navbar__countdown-label {
        font-size: var(--fs-6);
        opacity: 0.7;
    }

    .navbar__countdown-sep {
        color: var(--c-brand);
        font-size: var(--fs-5);
        opacity: 0.5;
    }

    .navbar__links {
        gap: var(--s-4);
        justify-self: end;
    }

    .navbar__cta {
        animation: cta-pulse 2s ease-in-out infinite;
        background: var(--c-brand);
        border-radius: var(--r-2);
        box-shadow: 0 3px 15px color-mix(in srgb, var(--c-brand) 40%, transparent);
        color: var(--c-text);
        font-size: var(--fs-6);
        font-weight: 800;
        height: var(--s-2);
        letter-spacing: 0.05em;
        line-height: 1;
        padding: 0 var(--s-4);
        transition:
            background var(--xs-4),
            box-shadow var(--xs-4),
            transform var(--xs-4);
    }

    .navbar__cta:hover {
        animation: none;
        background: color-mix(in srgb, var(--c-brand), black 10%);
        box-shadow: 0 5px 25px color-mix(in srgb, var(--c-brand) 70%, transparent);
        transform: scale(1.05);
    }

    .navbar__burger {
        background: color-mix(in srgb, var(--c-text) 5%, transparent);
        border: 1px solid color-mix(in srgb, var(--c-text) 15%, transparent);
        border-radius: var(--r-2);
        color: var(--c-text);
        height: var(--s-2);
        transition:
            background var(--xs-4),
            border-color var(--xs-4);
        width: var(--s-2);
    }

    .navbar__burger:hover {
        background: color-mix(in srgb, var(--c-text) 5%, transparent);
        border-color: color-mix(in srgb, var(--c-text) 50%, transparent);
    }

    .navbar__menu {
        backdrop-filter: blur(16px);
        background: color-mix(in srgb, var(--c-base) 95%, transparent);
        bottom: 0;
        gap: var(--s-2);
        left: 0;
        opacity: 0;
        right: 0;
        top: var(--l-nav);
        transition: opacity var(--xs-3);
        z-index: 99;
        -webkit-backdrop-filter: blur(16px);
    }

    .navbar__menu[data-open] {
        opacity: 1;
        pointer-events: auto;
    }

    .navbar__menu-link:focus-visible {
        color: var(--c-brand);
        outline: 2px solid var(--c-brand);
        outline-offset: 4px;
    }

    @media (prefers-reduced-motion: reduce) {
        .navbar__menu {
            transition: none;
        }

        .navbar__cta {
            animation: none;
        }

        .navbar__cta:hover {
            transform: none;
        }

        .navbar__burger {
            transition: none;
        }
    }

    .navbar__menu-link {
        color: var(--c-text);
        font-family: var(--ff-heading);
        font-size: var(--fs-2);
        letter-spacing: 0.05em;
        transition: color var(--xs-4);
    }

    .navbar__menu-link:hover {
        color: var(--c-brand);
    }

    .navbar__menu-divider {
        border-top: 1px solid color-mix(in srgb, var(--c-text) 15%, transparent);
        margin: var(--s-4) 0;
        width: var(--l-1);
    }


    @media (prefers-contrast: more) {
        .navbar__cta {
            outline: 2px solid var(--c-text);
        }
    }

    @media (forced-colors: active) {
        .navbar__cta {
            border: 2px solid currentColor;
        }
    }

    @keyframes cta-pulse {
        0%,
        100% {
            box-shadow: 0 3px 15px color-mix(in srgb, var(--c-brand) 40%, transparent);
        }
        50% {
            box-shadow: 0 3px 20px color-mix(in srgb, var(--c-brand) 70%, transparent);
        }
    }
</style>

<script>
    const MS_PER_DAY = 86400000;
    const MS_PER_HOUR = 3600000;
    const MS_PER_MINUTE = 60000;
    const MS_PER_SECOND = 1000;
    const PAD_LENGTH = 2;
    const EVENT_DATE = new Date('2026-07-18T19:00:00-05:00').getTime();

    const countdownContainer = document.querySelector('.navbar__countdown') as HTMLElement | null;
    const countdownElements = {
        days: document.getElementById('countdown-days'),
        hours: document.getElementById('countdown-hours'),
        mins: document.getElementById('countdown-mins'),
        secs: document.getElementById('countdown-secs'),
    };

    function updateCountdown(): void {
        const remaining = EVENT_DATE - Date.now();

        if (remaining <= 0) {
            if (countdownContainer) {
                countdownContainer.innerHTML = '<span class="navbar__countdown-val" style="font-size:var(--fs-3);letter-spacing:0.1em">HAPPENING NOW</span>';
            }
            clearInterval(countdownInterval);
            return;
        }

        const days = Math.floor(remaining / MS_PER_DAY);
        const hours = Math.floor((remaining % MS_PER_DAY) / MS_PER_HOUR);
        const minutes = Math.floor((remaining % MS_PER_HOUR) / MS_PER_MINUTE);
        const seconds = Math.floor((remaining % MS_PER_MINUTE) / MS_PER_SECOND);

        if (countdownElements.days) {
            countdownElements.days.textContent = String(days).padStart(PAD_LENGTH, '0');
        }

        if (countdownElements.hours) {
            countdownElements.hours.textContent = String(hours).padStart(PAD_LENGTH, '0');
        }

        if (countdownElements.mins) {
            countdownElements.mins.textContent = String(minutes).padStart(PAD_LENGTH, '0');
        }

        if (countdownElements.secs) {
            countdownElements.secs.textContent = String(seconds).padStart(PAD_LENGTH, '0');
        }
    }

    updateCountdown();
    const countdownInterval = setInterval(updateCountdown, MS_PER_SECOND);

    const burger = document.querySelector('.navbar__burger') as HTMLButtonElement | null;
    const burgerIcon = burger?.querySelector('.burger-icon') as SVGElement | null;
    const menu = document.querySelector('.navbar__menu') as HTMLElement | null;
    const menuLinks = menu?.querySelectorAll('.navbar__menu-link') as NodeListOf<HTMLAnchorElement>;

    function openMenu(): void {
        burgerIcon?.setAttribute('data-open', '');
        menu?.setAttribute('data-open', '');
        burger?.setAttribute('aria-expanded', 'true');
        menu?.setAttribute('aria-hidden', 'false');
        if (menuLinks?.length) menuLinks[0].focus();
    }

    function closeMenu(): void {
        burgerIcon?.removeAttribute('data-open');
        menu?.removeAttribute('data-open');
        burger?.setAttribute('aria-expanded', 'false');
        menu?.setAttribute('aria-hidden', 'true');
        burger?.focus();
    }

    function isMenuOpen(): boolean {
        return menu?.hasAttribute('data-open') ?? false;
    }

    burger?.addEventListener('click', () => {
        if (isMenuOpen()) {
            closeMenu();
        } else {
            openMenu();
        }
    });

    document.addEventListener('keydown', (e) => {
        if (!isMenuOpen() || !menuLinks) return;

        if (e.key === 'Escape') {
            closeMenu();
            return;
        }

        if (e.key === 'Tab') {
            const focusable = Array.from(menuLinks);
            const first = focusable[0];
            const last = focusable[focusable.length - 1];

            if (e.shiftKey && document.activeElement === first) {
                e.preventDefault();
                last.focus();
            } else if (!e.shiftKey && document.activeElement === last) {
                e.preventDefault();
                first.focus();
            }
        }
    });
</script>
