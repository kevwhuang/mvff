---
import BurgerIcon from '@components/icons/Burger.astro';
import logo from '@assets/images/logos/mvff.png';
---

<nav class="nav fixed flex items-center" aria-label="Main">
    <div class="nav__inner flex items-center justify-between">
        <a class="nav__logo flex items-center" aria-label="ATX MVFF Home" href="/">
            <img class="nav__logo-img select-none" alt="" src={logo.src} />
        </a>
        <div class="nav__countdown select-none" aria-label="Countdown to event">
            <div class="nav__countdown-num flex flex-col items-center">
                <span id="countdown-days" class="nav__countdown-val">--</span>
                <span class="nav__countdown-label uppercase">Days</span>
            </div>
            <span class="nav__countdown-sep">:</span>
            <div class="nav__countdown-num flex flex-col items-center">
                <span id="countdown-hours" class="nav__countdown-val">--</span>
                <span class="nav__countdown-label uppercase">Hrs</span>
            </div>
            <span class="nav__countdown-sep">:</span>
            <div class="nav__countdown-num flex flex-col items-center">
                <span id="countdown-mins" class="nav__countdown-val">--</span>
                <span class="nav__countdown-label uppercase">Min</span>
            </div>
            <span class="nav__countdown-sep">:</span>
            <div class="nav__countdown-num flex flex-col items-center">
                <span id="countdown-secs" class="nav__countdown-val">--</span>
                <span class="nav__countdown-label uppercase">Sec</span>
            </div>
        </div>
        <div class="nav__links flex items-center justify-end">
            <a
                class="nav__cta inline-flex items-center justify-center uppercase no-underline text-center"
                aria-label="Submit your music video"
                href="https://filmfreeway.com/atxmusicvideofilmfestival"
                rel="noopener noreferrer"
                target="_blank"
            >
                Submit Video<span class="sr-only"> (opens in new tab)</span>
            </a>
            <button class="nav__burger inline-flex items-center justify-center" aria-expanded="false" aria-label="Open menu">
                <BurgerIcon />
            </button>
        </div>
    </div>
</nav>
<div class="nav__menu fixed flex flex-col items-center justify-center pointer-events-none" aria-hidden="true">
    <a class="nav__menu-link no-underline" href="/">Home</a>
    <a class="nav__menu-link no-underline" href="/teams">Team</a>
    <div class="nav__menu-divider"></div>
    <a class="nav__menu-link no-underline" href="pitch-deck.pdf" rel="noopener noreferrer" target="_blank">Pitch Deck</a>
    <a class="nav__menu-link no-underline" href="https://calendly.com/madewellanna99/30min" rel="noopener noreferrer" target="_blank">Schedule a Call</a>
</div>

<style>
    .nav {
        backdrop-filter: blur(10px);
        background: var(--c-overlay);
        border-bottom: 1px solid var(--c-border);
        height: var(--nav-h);
        inset: 0 0 auto;
        z-index: 100;
    }

    .nav__inner {
        gap: clamp(10px, calc(10px + 20 * (100vw - 320px) / 1216), 30px);
        margin: 0 auto;
        max-width: var(--max-w);
        padding: 0 clamp(10px, calc(10px + 20 * (100vw - 320px) / 1216), 30px);
        width: 100%;
    }

    .nav__logo-img {
        height: clamp(30px, calc(30px + 20 * (100vw - 320px) / 1216), 50px);
        width: auto;
    }

    .nav__countdown {
        align-items: center;
        color: var(--c-text-muted);
        display: none;
        font-family: var(--f-body);
        font-size: var(--fs-6);
        font-weight: 600;
        gap: clamp(6px, calc(6px + 4 * (100vw - 320px) / 1216), 10px);
        height: clamp(30px, calc(30px + 20 * (100vw - 320px) / 1216), 50px);
        letter-spacing: 0.05em;
    }

    .nav__countdown-num {
        min-width: clamp(18px, calc(18px + 12 * (100vw - 320px) / 1216), 30px);
    }

    .nav__countdown-val {
        color: var(--c-accent);
        font-family: var(--f-display);
        font-size: var(--fs-3);
        line-height: 1;
    }

    .nav__countdown-label {
        font-size: var(--fs-6);
        opacity: 0.7;
    }

    .nav__countdown-sep {
        color: var(--c-accent);
        font-size: var(--fs-5);
        opacity: 0.5;
    }

    .nav__links {
        gap: clamp(10px, calc(10px + 5 * (100vw - 320px) / 1216), 15px);
    }

    .nav__cta {
        animation: cta-glow 2s ease-in-out infinite;
        background: var(--c-accent);
        border-radius: clamp(4px, calc(4px + 4 * (100vw - 320px) / 1216), 8px);
        box-shadow: 0 3px 15px rgba(255, 77, 109, 0.4);
        color: var(--c-text);
        font-size: var(--fs-6);
        font-weight: 800;
        height: clamp(30px, calc(30px + 20 * (100vw - 320px) / 1216), 50px);
        letter-spacing: 0.05em;
        line-height: 1;
        padding: 0 clamp(10px, calc(10px + 5 * (100vw - 320px) / 1216), 15px);
        transition:
            background var(--ease),
            box-shadow var(--ease),
            transform var(--ease);
    }

    .nav__cta:hover {
        animation: none;
        background: var(--c-accent-dark);
        box-shadow: 0 5px 25px rgba(255, 77, 109, 0.7);
        transform: scale(1.05);
    }

    .nav__burger {
        background: var(--c-surface);
        border: 1px solid var(--c-border);
        border-radius: clamp(4px, calc(4px + 4 * (100vw - 320px) / 1216), 8px);
        color: var(--c-text);
        height: clamp(30px, calc(30px + 20 * (100vw - 320px) / 1216), 50px);
        transition:
            background var(--ease),
            border-color var(--ease);
        width: clamp(30px, calc(30px + 20 * (100vw - 320px) / 1216), 50px);
    }

    .nav__burger:hover {
        background: var(--c-surface);
        border-color: rgba(255, 255, 255, 0.5);
    }

    .nav__menu {
        backdrop-filter: blur(16px);
        background: rgba(10, 15, 26, 0.95);
        bottom: 0;
        gap: var(--s-lg);
        left: 0;
        opacity: 0;
        right: 0;
        top: var(--nav-h);
        transition: opacity var(--ease-md);
        z-index: 99;
        -webkit-backdrop-filter: blur(16px);
    }

    .nav__menu--open {
        opacity: 1;
        pointer-events: auto;
    }

    .nav__menu-link {
        color: var(--c-text);
        font-family: var(--f-display);
        font-size: var(--fs-2);
        letter-spacing: 0.05em;
        transition: color var(--ease);
    }

    .nav__menu-link:hover {
        color: var(--c-accent);
    }

    .nav__menu-divider {
        border-top: 1px solid var(--c-border);
        margin: var(--s-xs) 0;
        width: 350px;
    }

    @keyframes cta-glow {
        0%,
        100% {
            box-shadow: 0 3px 15px rgba(255, 77, 109, 0.4);
        }
        50% {
            box-shadow: 0 3px 20px rgba(255, 77, 109, 0.7);
        }
    }

    @media (min-width: 768px) {
        .nav__inner {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
        }

        .nav__countdown {
            display: flex;
        }

        .nav__links {
            justify-self: end;
        }
    }

    @media (min-width: 1024px) {
        .nav__inner {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
        }

        .nav__links {
            gap: var(--s-md);
        }
    }

    @media (prefers-contrast: more) {
        .nav__cta {
            outline: 2px solid #fff;
        }
    }

    @media (forced-colors: active) {
        .nav__cta {
            border: 2px solid currentColor;
        }
    }
</style>

<script is:inline>
    (() => {
        const eventDate = new Date('2026-07-18T19:00:00-05:00').getTime();
        const countdownEls = {
            days: document.getElementById('countdown-days'),
            hours: document.getElementById('countdown-hours'),
            mins: document.getElementById('countdown-mins'),
            secs: document.getElementById('countdown-secs'),
        };
        const countdownContainer = document.querySelector('.nav__countdown');
        const updateCountdown = () => {
            const now = Date.now();
            const diff = eventDate - now;
            if (diff <= 0) {
                countdownContainer.innerHTML = '<span class="nav__countdown-val" style="font-size:var(--fs-3);letter-spacing:0.1em">HAPPENING NOW</span>';
                clearInterval(countdownInterval);
                return;
            }
            const d = Math.floor(diff / 86400000);
            const h = Math.floor((diff % 86400000) / 3600000);
            const m = Math.floor((diff % 3600000) / 60000);
            const s = Math.floor((diff % 60000) / 1000);
            if (countdownEls.days)
                countdownEls.days.textContent = String(d).padStart(2, '0');
            if (countdownEls.hours)
                countdownEls.hours.textContent = String(h).padStart(2, '0');
            if (countdownEls.mins)
                countdownEls.mins.textContent = String(m).padStart(2, '0');
            if (countdownEls.secs)
                countdownEls.secs.textContent = String(s).padStart(2, '0');
        };
        updateCountdown();
        const countdownInterval = setInterval(() => {
            updateCountdown();
        }, 1000);
        const burger = document.querySelector('.nav__burger');
        const burgerIcon = burger.querySelector('.burger-icon');
        const menu = document.querySelector('.nav__menu');
        burger.addEventListener('click', () => {
            const isOpen = burgerIcon.toggleAttribute('data-open');
            menu.classList.toggle('nav__menu--open');
            burger.setAttribute('aria-expanded', isOpen);
            menu.setAttribute('aria-hidden', !isOpen);
        });
    })();
</script>
