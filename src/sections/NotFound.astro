<section
    class="not-found flex items-center justify-center min-h-screen px-10 bg-zinc-950"
>
    <div class="not-found__content text-center select-none">
        <h1
            class="not-found__title mb-12 font-bold text-[15rem] tracking-widest"
        >
            404
        </h1>
        <a
            class="not-found__link inline-block min-h-14 px-10 py-5 border border-white/20 font-mono text-sm lowercase tracking-[0.2em] text-white/70"
            aria-label="Return to home"
            href="/"
        >
            return
        </a>
    </div>
</section>

<style>
    .not-found__title {
        background: linear-gradient(
            180deg,
            color-mix(in srgb, var(--c-text) 90%, transparent) 0%,
            color-mix(in srgb, var(--c-text) 40%, transparent) 100%
        );
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .not-found__link {
        transition: all var(--xs-3);
    }

    .not-found__link:hover {
        background-color: color-mix(in srgb, var(--c-text) 5%, transparent);
        border-color: color-mix(in srgb, var(--c-brand) 50%, transparent);
        color: color-mix(in srgb, var(--c-brand) 90%, transparent);
        text-shadow: 0 0 20px color-mix(in srgb, var(--c-brand) 30%, transparent);
    }
</style>
