---
import type { ImageMetadata } from 'astro';

interface Props {
    image: ImageMetadata;
    name: string;
    title: string;
}

const { image, name, title } = Astro.props;
---

<li class="team-card flex flex-col items-center overflow-hidden">
    <img class="team-card__img rounded-full object-cover pointer-events-none select-none" alt={name} draggable="false" src={image.src} />
    <span class="team-card__name">{name}</span>
    <span class="team-card__role uppercase">{title}</span>
</li>

<style>
    .team-card {
        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--c-text) 4%, transparent) 0%,
            color-mix(in srgb, var(--c-text) 1%, transparent) 100%
        );
        border: 1px solid color-mix(in srgb, var(--c-text) 15%, transparent);
        border-radius: var(--r-1);
        gap: var(--s-4);
        padding: var(--s-2);
        transition:
            background var(--xs-3),
            border-color var(--xs-3),
            transform var(--xs-3);
    }

    .team-card__img {
        aspect-ratio: 1;
        height: auto;
        margin-bottom: var(--s-4);
        width: var(--fs-1);
    }

    .team-card__name {
        font-family: var(--ff-heading);
        font-size: var(--fs-3);
        letter-spacing: 0.02em;
    }

    .team-card__role {
        color: var(--c-brand);
        font-size: var(--fs-5);
        font-weight: 700;
        letter-spacing: 0.05em;
    }

    .team-card:hover {
        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--c-text) 7%, transparent) 0%,
            color-mix(in srgb, var(--c-text) 2%, transparent) 100%
        );
        border-color: color-mix(in srgb, var(--c-brand) 50%, transparent);
        transform: translateY(-4px);
    }
</style>
