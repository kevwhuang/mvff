---
interface Props {
    delay: string;
    label: string;
    value: string;
}

const { delay, label, value } = Astro.props;
---

<li class="details-card relative flex flex-col items-center text-center" data-scroll data-scroll-delay={delay}>
    <slot />
    <span class="details-card__label relative uppercase">{label}</span>
    <span class="details-card__value relative" set:html={value} />
</li>

<style>
    .details-card {
        backdrop-filter: blur(8px);
        background: color-mix(in srgb, var(--c-text) 5%, transparent);
        border: 1px solid color-mix(in srgb, var(--c-text) 10%, transparent);
        border-radius: var(--r-1);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        contain: layout style paint;
        flex: 1 1 0;
        min-width: 0;
        padding: var(--s-2) var(--s-3);
        transform-style: preserve-3d;
        transition:
            box-shadow var(--xs-3),
            opacity var(--xs-1),
            transform var(--xs-4);
        -webkit-backdrop-filter: blur(8px);
    }

    .details-card:hover {
        box-shadow: 0 16px 48px color-mix(in srgb, var(--c-brand) 25%, transparent);
    }

    .details-card:hover::before {
        animation-play-state: running;
        opacity: 1;
    }

    .details-card::before {
        animation: border-glow 4s linear infinite paused;
        background: linear-gradient(
            var(--gradient-angle),
            var(--c-brand),
            var(--c-indigo),
            var(--c-cyan),
            var(--c-brand)
        );
        border-radius: var(--r-1);
        content: "";
        inset: 0;
        mask:
            linear-gradient(#fff 0 0) content-box,
            linear-gradient(#fff 0 0);
        mask-composite: exclude;
        opacity: 0;
        padding: 1px;
        position: absolute;
        transition: opacity var(--xs-3);
        z-index: 0;
        -webkit-mask:
            linear-gradient(#fff 0 0) content-box,
            linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
    }

    .details-card__label {
        color: var(--c-muted);
        font-family: var(--ff-body);
        font-size: var(--fs-6);
        font-weight: 500;
        letter-spacing: 0.1em;
        margin-bottom: var(--s-4);
        z-index: 1;
    }

    .details-card__value {
        color: var(--c-text);
        font-family: var(--ff-heading);
        font-size: var(--fs-4);
        letter-spacing: 0.02em;
        z-index: 1;
    }


    @property --gradient-angle {
        inherits: false;
        initial-value: 0deg;
        syntax: "<angle>";
    }

    @keyframes border-glow {
        to {
            --gradient-angle: 360deg;
        }
    }
</style>
