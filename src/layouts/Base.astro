---
import '@fontsource/archivo-black';
import '@fontsource/space-grotesk';
import { ClientRouter } from 'astro:transitions';

import Cursor from '@components/ui/Cursor.astro';
import Footer from '@sections/Footer.astro';
import Navbar from '@sections/Navbar.astro';
import ScrollProgress from '@components/ui/ScrollProgress.astro';

interface Props {
    description: string;
    title: string;
}

const { description, title } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta content="width=device-width, initial-scale=1" name="viewport" />
        <title>{title}</title>
        <meta content="Kevin Huang" name="author" />
        <meta content={description} name="description" />
        <meta content="#0c0e18" name="theme-color" />
        <link href={canonicalUrl} rel="canonical" />
        <link href="/favicon.png" rel="icon" type="image/png" />
        <meta content={title} property="og:title" />
        <meta content={description} property="og:description" />
        <meta content={canonicalUrl} property="og:url" />
        <meta content="website" property="og:type" />
        <meta content={`${Astro.site}og.png`} property="og:image" />
        <meta content="ATX Music Video Film Festival" property="og:site_name" />
        <meta content="summary_large_image" name="twitter:card" />
        <meta content={title} name="twitter:title" />
        <meta content={description} name="twitter:description" />
        <meta content={`${Astro.site}og.png`} name="twitter:image" />
        <script
            set:html={JSON.stringify({
                '@context': 'https://schema.org',
                '@type': 'WebSite',
                'founder': {
                    '@type': 'Person',
                    'name': 'Anna Madewell',
                },
                'name': 'ATX Music Video Film Festival',
                'url': Astro.site,
            })}
            type="application/ld+json"
        />
        <ClientRouter />
    </head>
    <body>
        <Cursor />
        <ScrollProgress />
        <Navbar />
        <main>
            <slot />
        </main>
        <Footer />
    </body>
</html>

<style is:global>
    @import 'tailwindcss';

    :root {
        --c-base: rgb(12, 14, 24);
        --c-brand: rgb(240, 80, 105);
        --c-cyan: rgb(45, 200, 225);
        --c-indigo: rgb(110, 100, 220);
        --c-muted: rgb(175, 175, 185);
        --c-text: rgb(245, 245, 250);
        --ff-body: 'Space Grotesk', system-ui, sans-serif;
        --ff-heading: 'Archivo Black', Impact, sans-serif;
        --fs-1: 120px;
        --fs-2: 80px;
        --fs-3: 54px;
        --fs-4: 36px;
        --fs-5: 24px;
        --fs-6: 16px;
        --l-1: 400px;
        --l-2: 200px;
        --l-3: 100px;
        --l-max: 1640px;
        --l-min: 320px;
        --l-nav: 100px;
        --r-1: 16px;
        --r-2: 8px;
        --r-3: 4px;
        --s-1: 80px;
        --s-2: 40px;
        --s-3: 20px;
        --s-4: 10px;
        --xs-1: 1200ms ease-out;
        --xs-2: 600ms ease;
        --xs-3: 300ms ease;
        --xs-4: 150ms ease;
    }

    a,
    button {
        cursor: none;
    }

    body {
        background: var(--c-base);
        color: var(--c-text);
        cursor: none;
        font-family: var(--ff-body);
        font-size: var(--fs-5);
        font-weight: 600;
        line-height: 1.6;
        min-height: 100vh;
        overflow-x: hidden;
    }

    html {
        overflow-x: clip;
        scroll-behavior: smooth;
    }

    :focus {
        outline: none;
    }

    :focus-visible {
        outline: 2px solid var(--c-brand);
        outline-offset: 2px;
    }

    [data-scroll] {
        opacity: 0;
    }

    @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
            animation-duration: 0.01ms !important;
            animation-iteration-count: 1 !important;
            scroll-behavior: auto !important;
            transition-duration: 0.01ms !important;
        }
    }
</style>

<script>
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import gsap from 'gsap';

    import { initScrambleAnimations } from '@lib/scramble';
    import { initScrollAnimations } from '@lib/scroll';

    gsap.registerPlugin(ScrollTrigger);

    const PERCENT_SCALE = 100;
    let cursorRafPending = false;
    let cursorX = 0;
    let cursorY = 0;
    let scrollRafPending = false;

    function init(): void {
        initScrambleAnimations();
        initScrollAnimations();

        const cursor = document.querySelector('.cursor') as HTMLElement | null;
        const dot = document.querySelector('.cursor__dot') as HTMLElement | null;
        const layers = document.querySelectorAll<HTMLElement>('[data-parallax]');
        const scrollProgressBar = document.querySelector('.scroll-progress') as HTMLElement | null;

        function updateScrollProgress(): void {
            if (!scrollProgressBar) return;
            const scrollTop = window.scrollY;
            const documentHeight = document.documentElement.scrollHeight - window.innerHeight;
            const progress = (scrollTop / documentHeight) * PERCENT_SCALE;
            scrollProgressBar.style.width = progress + '%';
        }

        function updateParallax(): void {
            const scrollY = window.scrollY;

            layers.forEach((layer) => {
                layer.style.transform = 'translateY(' + (scrollY * +(layer.dataset.parallax || 0)) + 'px)';
            });

            updateScrollProgress();
            scrollRafPending = false;
        }

        function updateCursor(): void {
            if (cursor) cursor.style.transform = 'translate(' + cursorX + 'px, ' + cursorY + 'px)';
            if (dot) dot.style.transform = 'translate(' + cursorX + 'px, ' + cursorY + 'px)';
            cursorRafPending = false;
        }

        window.addEventListener(
            'scroll',
            () => {
                if (!scrollRafPending) {
                    requestAnimationFrame(updateParallax);
                    scrollRafPending = true;
                }
            },
            { passive: true },
        );

        document.addEventListener(
            'mousemove',
            (event) => {
                cursorX = event.clientX;
                cursorY = event.clientY;

                if (!cursorRafPending) {
                    cursorRafPending = true;
                    requestAnimationFrame(updateCursor);
                }
            },
            { passive: true },
        );

        document.querySelectorAll('a, button').forEach((element) => {
            element.addEventListener('mouseenter', () => {
                cursor?.setAttribute('data-hover', '');
            });

            element.addEventListener('mouseleave', () => {
                cursor?.removeAttribute('data-hover');
            });
        });
    }

    init();
    document.addEventListener('astro:page-load', init);
</script>
